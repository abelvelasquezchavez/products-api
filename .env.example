# Server
PORT=3000
NODE_ENV=development

# Database (MySQL)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://products:products@localhost:3306/products"

# JWT
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="1d"

# Docker Compose MySQL credentials (used by docker-compose.yml)
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=products
MYSQL_USER=products
MYSQL_PASSWORD=products
